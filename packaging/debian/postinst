#!/bin/bash
set -e

if [ "$1" = "configure" ]; then
    systemd-sysusers /usr/lib/sysusers.d/vstimd.conf

    # Register the "Boot to vstimd" bootloader entry.
    # Failures are non-fatal — the user can run vstimd-boot-entry manually.
    vstimd-boot-entry 2>&1 | sed 's/^/vstimd: /' || true
fi

#DEBHELPER#
