#!/bin/bash
# vstimd-boot-entry — add a "Boot to vstimd" bootloader entry
#
# Detects grubby (Fedora/RHEL), GRUB2 with update-grub (Ubuntu/Debian),
# or extlinux (Jetson, Raspberry Pi) and registers a boot entry that boots
# into vstimd.target (no display manager, vstimd starts automatically).
#
# Safe to run multiple times — exits cleanly if the entry already exists.
# Must be run as root (except with --dry-run).
set -euo pipefail

TITLE="Boot to vstimd"
KARG="systemd.unit=vstimd.target"
GRUB_SCRIPT="/etc/grub.d/40_vstimd"
EXTLINUX_LABEL="vstimd"
EXTLINUX_PATHS=(
    /boot/extlinux/extlinux.conf
    /boot/firmware/extlinux/extlinux.conf
)

DRY_RUN=0

die()  { echo "vstimd-boot-entry: error: $*" >&2; exit 1; }
info() { echo "vstimd-boot-entry: $*"; }

# Write a file (or print it in dry-run mode).
write_file() {
    local path=$1 content=$2 mode=${3:-644}
    if [ "$DRY_RUN" -eq 1 ]; then
        echo "--- would write $path (mode $mode) ---"
        echo "$content"
        echo "---"
    else
        echo "$content" > "$path"
        chmod "$mode" "$path"
    fi
}

# Run a command (or print it in dry-run mode).
run_cmd() {
    if [ "$DRY_RUN" -eq 1 ]; then
        echo "  would run: $*"
    else
        "$@"
    fi
}

# ── grubby (Fedora / RHEL / AlmaLinux / Rocky) ───────────────────────────────

try_grubby() {
    command -v grubby >/dev/null 2>&1 || return 1

    if [ "$DRY_RUN" -eq 0 ]; then
        if grubby --info=ALL 2>/dev/null | grep -q "title=${TITLE}"; then
            info "entry already present (grubby) — nothing to do"
            return 0
        fi
        local kernel
        kernel=$(grubby --default-kernel) || die "grubby --default-kernel failed"
        info "detected bootloader: grubby (kernel: $kernel)"
        grubby --copy-default --add-kernel="$kernel" --title="$TITLE" --args="$KARG"
        info "boot entry added"
    else
        info "detected bootloader: grubby"
        echo "  would run: grubby --copy-default --add-kernel=\$(grubby --default-kernel) \\"
        echo "               --title='${TITLE}' --args='${KARG}'"
    fi
    return 0
}

# ── GRUB2 with update-grub (Ubuntu / Debian) ─────────────────────────────────
#
# Writes /etc/grub.d/40_vstimd — an executable generator script that grub-
# mkconfig runs on every update-grub call, so the entry always uses the
# current default kernel.

try_update_grub() {
    command -v update-grub >/dev/null 2>&1 || return 1

    if [ "$DRY_RUN" -eq 0 ] && [ -f "$GRUB_SCRIPT" ]; then
        info "entry already present ($GRUB_SCRIPT) — nothing to do"
        return 0
    fi

    command -v grub-probe >/dev/null 2>&1 || die "grub-probe not found"

    local root_uuid
    root_uuid=$(grub-probe --target=fs_uuid /) \
        || die "could not determine root filesystem UUID"

    info "detected bootloader: update-grub (root UUID: $root_uuid)"

    local script_content
    script_content=$(cat << SCRIPT
#!/bin/sh
# Generated by vstimd-boot-entry — do not edit by hand.
# Removed by: vstimd-boot-entry --remove  or  apt remove vstimd
set -e
KERNEL=\$(ls /boot/vmlinuz-* 2>/dev/null | sort -V | tail -1)
INITRD=\$(ls /boot/initrd.img-* 2>/dev/null | sort -V | tail -1)
[ -z "\$KERNEL" ] || [ -z "\$INITRD" ] && exit 0
printf 'menuentry "${TITLE}" {\\n'
printf '    search --no-floppy --fs-uuid --set=root ${root_uuid}\\n'
printf '    linux  %s root=UUID=${root_uuid} ro quiet ${KARG}\\n' "\$KERNEL"
printf '    initrd %s\\n' "\$INITRD"
printf '}\\n'
SCRIPT
)
    write_file "$GRUB_SCRIPT" "$script_content" 755
    run_cmd update-grub
    if [ "$DRY_RUN" -eq 0 ]; then info "boot entry added ($GRUB_SCRIPT)"; fi
    return 0
}

# ── GRUB2 with grub2-mkconfig (Fedora without grubby, Arch, etc.) ────────────

try_grub2_mkconfig() {
    command -v grub2-mkconfig >/dev/null 2>&1 || return 1
    [ -d /etc/grub.d ] || return 1

    if [ "$DRY_RUN" -eq 0 ] && [ -f "$GRUB_SCRIPT" ]; then
        info "entry already present ($GRUB_SCRIPT) — nothing to do"
        return 0
    fi

    local probe
    probe=$(command -v grub2-probe 2>/dev/null || command -v grub-probe 2>/dev/null) \
        || die "grub-probe / grub2-probe not found"

    local root_uuid
    root_uuid=$("$probe" --target=fs_uuid /) \
        || die "could not determine root filesystem UUID"

    local cfg=""
    for p in /boot/grub2/grub.cfg /boot/efi/EFI/*/grub.cfg /boot/grub/grub.cfg; do
        [ -f "$p" ] && cfg=$p && break
    done
    [ -n "$cfg" ] || die "could not find grub.cfg"

    info "detected bootloader: grub2-mkconfig (root UUID: $root_uuid, cfg: $cfg)"

    local script_content
    script_content=$(cat << SCRIPT
#!/bin/sh
# Generated by vstimd-boot-entry — do not edit by hand.
set -e
KERNEL=\$(ls /boot/vmlinuz-* /boot/Image-* 2>/dev/null | sort -V | tail -1)
INITRD=\$(ls /boot/initrd.img-* /boot/initramfs-*.img 2>/dev/null | sort -V | tail -1)
[ -z "\$KERNEL" ] && exit 0
printf 'menuentry "${TITLE}" {\\n'
printf '    search --no-floppy --fs-uuid --set=root ${root_uuid}\\n'
printf '    linux  %s root=UUID=${root_uuid} ro quiet ${KARG}\\n' "\$KERNEL"
[ -n "\$INITRD" ] && printf '    initrd %s\\n' "\$INITRD"
printf '}\\n'
SCRIPT
)
    write_file "$GRUB_SCRIPT" "$script_content" 755
    run_cmd grub2-mkconfig -o "$cfg"
    if [ "$DRY_RUN" -eq 0 ]; then info "boot entry added ($cfg)"; fi
    return 0
}

# ── extlinux (Jetson, Raspberry Pi, embedded) ─────────────────────────────────

try_extlinux() {
    local conf=""
    for p in "${EXTLINUX_PATHS[@]}"; do
        [ -f "$p" ] && conf=$p && break
    done
    [ -n "$conf" ] || return 1

    if [ "$DRY_RUN" -eq 0 ] && grep -q "LABEL ${EXTLINUX_LABEL}" "$conf" 2>/dev/null; then
        info "entry already present ($conf) — nothing to do"
        return 0
    fi

    local template
    template=$(awk '
        /^LABEL / && !found { found=1; block=$0; next }
        found && /^LABEL /  { exit }
        found               { block = block "\n" $0 }
        END                 { print block }
    ' "$conf")
    [ -n "$template" ] || die "no LABEL block found in $conf"

    local new_entry
    new_entry=$(echo "$template" \
        | sed "s/^LABEL .*/LABEL ${EXTLINUX_LABEL}/" \
        | sed "s/MENU LABEL .*/MENU LABEL ${TITLE}/" \
        | sed "s/\(APPEND.*\)/\1 ${KARG}/")

    info "detected bootloader: extlinux ($conf)"
    if [ "$DRY_RUN" -eq 1 ]; then
        echo "--- would append to $conf ---"
        printf '\n%s\n' "$new_entry"
        echo "---"
    else
        printf '\n%s\n' "$new_entry" >> "$conf"
        info "boot entry appended to $conf"
    fi
    return 0
}

# ── Removal ───────────────────────────────────────────────────────────────────

do_remove() {
    local removed=0

    if command -v grubby >/dev/null 2>&1; then
        local kernel
        kernel=$(grubby --info=ALL 2>/dev/null \
            | awk -F= "/title=${TITLE}/{found=1} found && /^kernel=/{print \$2; exit}")
        if [ -n "$kernel" ]; then
            run_cmd grubby --remove-kernel="$kernel"
            info "removed grubby entry"
            removed=1
        fi
    fi

    if [ -f "$GRUB_SCRIPT" ]; then
        if [ "$DRY_RUN" -eq 1 ]; then
            echo "  would delete $GRUB_SCRIPT"
        else
            rm -f "$GRUB_SCRIPT"
        fi
        if command -v update-grub >/dev/null 2>&1; then
            run_cmd update-grub
        elif command -v grub2-mkconfig >/dev/null 2>&1; then
            for p in /boot/grub2/grub.cfg /boot/efi/EFI/*/grub.cfg /boot/grub/grub.cfg; do
                [ -f "$p" ] && run_cmd grub2-mkconfig -o "$p" && break
            done
        fi
        info "removed $GRUB_SCRIPT and regenerated GRUB config"
        removed=1
    fi

    for p in "${EXTLINUX_PATHS[@]}"; do
        if [ -f "$p" ] && grep -q "LABEL ${EXTLINUX_LABEL}" "$p" 2>/dev/null; then
            if [ "$DRY_RUN" -eq 1 ]; then
                echo "  would remove LABEL ${EXTLINUX_LABEL} block from $p"
            else
                awk "
                    /^LABEL ${EXTLINUX_LABEL}\$/ { skip=1 }
                    skip && /^LABEL / && !/^LABEL ${EXTLINUX_LABEL}\$/ { skip=0 }
                    !skip
                " "$p" > "${p}.tmp" && mv "${p}.tmp" "$p"
            fi
            info "removed entry from $p"
            removed=1
        fi
    done

    [ "$removed" -eq 1 ] || info "no boot entry found — nothing to remove"
}

# ── Main ──────────────────────────────────────────────────────────────────────

case "${1:-}" in
    --dry-run|-n)
        DRY_RUN=1
        info "dry-run mode — no changes will be made"
        ;;
    --remove|-r)
        [ "$(id -u)" -eq 0 ] || die "must be run as root"
        do_remove
        exit 0
        ;;
    --help|-h)
        echo "Usage: vstimd-boot-entry [--dry-run | --remove]"
        echo "  (no args)   detect bootloader and add 'Boot to vstimd' entry"
        echo "  --dry-run   show what would be done without making any changes"
        echo "  --remove    remove the boot entry"
        exit 0
        ;;
    "") ;;
    *) die "unknown argument '$1' (try --help)" ;;
esac

[ "$DRY_RUN" -eq 1 ] || [ "$(id -u)" -eq 0 ] || die "must be run as root"

try_grubby         && exit 0
try_update_grub    && exit 0
try_grub2_mkconfig && exit 0
try_extlinux       && exit 0

echo "vstimd-boot-entry: no supported bootloader detected — add the entry manually." >&2
echo "  See: /usr/share/doc/vstimd/deploy.md  (Boot to vstimd section)" >&2
exit 1
