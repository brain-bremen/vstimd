target/
.git/
# Exclude client/ except the web frontend, which the deb builder compiles and
# embeds into the binary (--features embed-ui). Keep node_modules / generated
# artifacts out so they're rebuilt cleanly (and never leak host-arch binaries).
client/
!client/web/
client/web/node_modules/
client/web/dist/
client/web/src/_proto/
client/web/test-results/
client/web/playwright-report/
extern/
docs/
dev/
tools/
# Built artifacts — excluded from build context except when needed by Dockerfile.test-deb.
# The .deb is explicitly included via the negation below.
packaging/*.rpm
packaging/*.changes
packaging/*.buildinfo
packaging/*.ddeb
log.txt
